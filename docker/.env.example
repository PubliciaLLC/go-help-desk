# Copy this file to .env and fill in the required values before running:
#   cp .env.example .env
#   docker compose up -d

# ─── Required ────────────────────────────────────────────────────────────────

# Public URL of the app (no trailing slash). Used in email links and SAML metadata.
BASE_URL=http://localhost:8080

# Secret used to sign session cookies. Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-in-production

# Secret used to sign JWTs for API bearer tokens. Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# ─── Email / SMTP (optional — notifications disabled when unset) ──────────────

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=secret
# SMTP_FROM=helpdesk@example.com

# ─── Feature flags (optional) ────────────────────────────────────────────────

# GUEST_SUBMISSION_ENABLED=false
# SLA_ENABLED=false
# MFA_ENABLED=false
