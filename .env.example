# ─── Required ────────────────────────────────────────────────────────────────

# Full Postgres connection string
DATABASE_URL=postgres://helpdesk:helpdesk@localhost:5432/helpdesk?sslmode=disable

# Public URL of the app (no trailing slash). Used for links in emails and SAML.
BASE_URL=http://localhost:8080

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# Secret used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# ─── Server (optional) ───────────────────────────────────────────────────────

HTTP_PORT=8080

# "development" enables extra logging and debug helpers
APP_ENV=production

# ─── Email / SMTP (optional — notifications disabled when unset) ──────────────

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=secret
# SMTP_FROM=helpdesk@example.com

# ─── SAML SSO (optional) ─────────────────────────────────────────────────────

# SAML_ENABLED=false
# SAML_METADATA_URL=https://idp.example.com/metadata
# SAML_CERT_FILE=/path/to/saml.crt
# SAML_KEY_FILE=/path/to/saml.key

# ─── Features (optional) ─────────────────────────────────────────────────────

# Allow unauthenticated users to submit tickets
# GUEST_SUBMISSION_ENABLED=false

# Enable SLA tracking
# SLA_ENABLED=false

# Enable multi-factor authentication
# MFA_ENABLED=false

# ─── Storage ─────────────────────────────────────────────────────────────────

# Directory where uploaded attachments are stored
ATTACHMENT_DIR=/data/attachments

# ─── Testing ─────────────────────────────────────────────────────────────────

# Postgres URL used by integration tests. Tests are skipped when this is unset.
# TEST_DATABASE_URL=postgres://helpdesk:helpdesk@localhost:5432/helpdesk?sslmode=disable
